---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        <span class="mission-title">Mission<span class="m-year">2035</span></span>
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">journey</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Recent prayer letter -->
    {% assign latest_letter = site.prayer | sort: 'date' | reverse | first %}
    {% if latest_letter %}
      <h2>
        <a href="{{ '/prayer/' | relative_url }}" style="color: inherit">recent prayer</a>
      </h2>
      <style>
        .rp-card { display: flex; gap: 1rem; text-decoration: none; color: inherit; margin-top: .6rem;
          border: 1px solid rgba(128,128,128,.18); border-radius: 14px; overflow: hidden;
          background: rgba(128,128,128,.03); transition: border-color .15s ease, transform .15s ease, box-shadow .15s ease; }
        .rp-card:hover { border-color: var(--global-theme-color); transform: translateY(-2px); box-shadow: 0 6px 22px rgba(0,0,0,.07); }
        .rp-card .rp-thumb { flex: 0 0 34%; max-width: 210px; background-size: cover; background-position: center; background-color: rgba(128,128,128,.1); }
        @media (max-width: 520px) { .rp-card { flex-direction: column; } .rp-card .rp-thumb { flex-basis: 150px; max-width: none; height: 150px; } }
        .rp-card .rp-body { padding: 1rem 1.15rem; display: flex; flex-direction: column; }
        .rp-card .rp-badge { align-self: flex-start; font-size: .68rem; font-weight: 800; letter-spacing: .04em;
          padding: .16rem .55rem; border-radius: 999px; background: var(--global-theme-color); color: #fff; margin-bottom: .45rem; }
        .rp-card h3 { margin: 0 0 .4rem; font-size: 1.08rem; line-height: 1.35; }
        .rp-card .rp-sum { font-size: .85rem; opacity: .7; line-height: 1.55; margin: 0; }
        .rp-viewall { display: inline-block; margin: .85rem 0 0; font-size: .82rem; text-decoration: none; color: var(--global-theme-color); }
        .rp-viewall:hover { text-decoration: underline; }
      </style>
      <a class="rp-card" href="{{ latest_letter.url | relative_url }}">
        {% if latest_letter.cover %}
          <div class="rp-thumb" style="background-image:url('{{ '/assets/img/gallery/' | append: latest_letter.cover | append: '.jpg' | relative_url }}');"></div>
        {% endif %}
        <div class="rp-body">
          <span class="rp-badge">{{ latest_letter.issue }}</span>
          <h3>{{ latest_letter.title | remove: latest_letter.issue | remove: ' · ' | strip }}</h3>
          {% if latest_letter.summary %}<p class="rp-sum">{{ latest_letter.summary }}</p>{% endif %}
        </div>
      </a>
      <a class="rp-viewall" href="{{ '/prayer/' | relative_url }}">View All Prayer Letters &rarr;</a>
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/diary/' | relative_url }}" style="color: inherit">recent reflections</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Photo preview -->
    {% if page.photo_preview %}
      <h2>
        <a href="{{ '/photos/' | relative_url }}" style="color: inherit">photos</a>
      </h2>
      <style>
        .photo-strip { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; margin: 0.6rem 0 0.3rem; }
        @media (min-width: 576px) { .photo-strip { grid-template-columns: repeat(5, 1fr); } }
        .photo-strip a { display: block; border-radius: 8px; overflow: hidden; aspect-ratio: 1 / 1; }
        .photo-strip img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
        .photo-strip a:hover img { transform: scale(1.06); }
        .photo-more { display: inline-block; margin-top: 0.5rem; font-size: 0.82rem; text-decoration: none; color: var(--global-theme-color); }
        .photo-more:hover { text-decoration: underline; }
      </style>
      <div class="photo-strip">
        {% assign preview_ids = "g24,g35,g38,g41,g53" | split: "," %}
        {% for id in preview_ids %}
          <a href="{{ '/photos/' | relative_url }}"><img loading="lazy" src="{{ '/assets/img/gallery/' | append: id | append: '.jpg' | relative_url }}" alt="photo"></a>
        {% endfor %}
      </div>
      <a class="photo-more" href="{{ '/photos/' | relative_url }}">View All Photos &rarr;</a>
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% if site.plugins contains 'al_newsletter' %}
        {% include plugins/al_newsletter_form_center_margin.liquid %}
      {% else %}
        {% include newsletter.liquid center=true %}
      {% endif %}
    {% endif %}
  </article>
</div>
