<style>
  /* Bold section headings across content pages */
  article h1, article h2, article h3, article h4,
  .post h1, .post h2, .post h3, .post h4,
  .post-title, .header-bar h1 {
    font-weight: 700 !important;
  }
  /* Special home title */
  .mission-title {
    font-weight: 800 !important;
    letter-spacing: -0.015em;
    background: linear-gradient(120deg, currentColor 60%, var(--global-theme-color));
    -webkit-background-clip: text;
    background-clip: text;
  }
  .mission-title .m-year {
    color: var(--global-theme-color);
    -webkit-text-fill-color: var(--global-theme-color);
  }
  /* Language toggle: Korean shown by default, English hidden until data-lang=en */
  .lang-en { display: none; }
  html[data-lang="en"] .lang-en { display: block; }
  html[data-lang="en"] .lang-ko { display: none; }
  .lang-toggle-btn {
    background: none; border: 1px solid rgba(128,128,128,.4); border-radius: 999px;
    font-size: 0.72rem; font-weight: 700; letter-spacing: .02em;
    padding: 0.08rem 0.5rem; margin-left: 0.2rem; cursor: pointer; color: inherit;
    line-height: 1.5; transition: all .15s ease;
  }
  .lang-toggle-btn:hover { border-color: var(--global-theme-color); color: var(--global-theme-color); }
  /* Keep the brand visible in the navbar (including the home page) */
  #navbar .navbar-brand.title { opacity: 1 !important; }
  /* Keep brand + nav on ONE row at desktop (the 930px cap made the long nav wrap under the name) */
  @media (min-width: 576px) {
    #navbar > .container { max-width: 1140px; flex-wrap: nowrap; }
    #navbar .navbar-collapse { flex-basis: auto; width: auto; }
    #navbar .navbar-nav { margin-left: auto; }
    #navbar .navbar-nav .nav-link { padding-left: 0.4rem; padding-right: 0.4rem; }
  }
  /* Back link on individual reflection posts */
  .diary-back { display: inline-block; margin: 0 0 1.2rem; font-size: .85rem; text-decoration: none; color: var(--global-theme-color); }
  .diary-back:hover { text-decoration: underline; }
</style>

<script>
  (function () {
    var KEY = 'siteLang';
    function apply(lang) {
      document.documentElement.setAttribute('data-lang', lang);
      var btn = document.getElementById('lang-toggle-btn');
      if (btn) { btn.textContent = lang === 'ko' ? 'EN' : '한'; btn.title = lang === 'ko' ? 'View in English' : '한국어로 보기'; }
    }
    apply(localStorage.getItem(KEY) || 'ko');
    function inject() {
      var tc = document.querySelector('.toggle-container');
      if (!tc || document.getElementById('lang-toggle-btn')) return;
      var li = document.createElement('li');
      li.className = 'toggle-container lang-toggle-li';
      var b = document.createElement('button');
      b.id = 'lang-toggle-btn'; b.type = 'button'; b.className = 'lang-toggle-btn';
      var cur = localStorage.getItem(KEY) || 'ko';
      b.textContent = cur === 'ko' ? 'EN' : '한';
      b.setAttribute('aria-label', 'Toggle language');
      b.addEventListener('click', function () {
        var c = localStorage.getItem(KEY) || 'ko';
        var n = c === 'ko' ? 'en' : 'ko';
        localStorage.setItem(KEY, n); apply(n);
      });
      li.appendChild(b);
      tc.parentNode.insertBefore(li, tc);
    }
    if (document.readyState !== 'loading') inject();
    else document.addEventListener('DOMContentLoaded', inject);
  })();

  (function () {
    // al-folio hides the navbar brand on the home page; show "Mission2035" there too.
    function addBrand() {
      if (document.querySelector('.navbar-brand')) return;
      var nav = document.querySelector('#navbar .container') || document.querySelector('nav .container');
      if (!nav) return;
      var a = document.createElement('a');
      a.className = 'navbar-brand title font-weight-lighter';
      a.href = '/';
      a.textContent = 'Se-Hyeon Hwang';
      a.style.opacity = '1';
      nav.insertBefore(a, nav.firstChild);
    }
    if (document.readyState !== 'loading') addBrand();
    else document.addEventListener('DOMContentLoaded', addBrand);
  })();

  (function () {
    // Back link on individual reflection (diary) posts
    if (!/^\/diary\/\d{4}\/[^/]+\/?$/.test(window.location.pathname)) return;
    function addBack() {
      if (document.querySelector('.diary-back')) return;
      var c = document.querySelector('.post') || document.querySelector('article');
      if (!c) return;
      var a = document.createElement('a');
      a.className = 'diary-back';
      a.href = '/diary/';
      a.innerHTML = '&larr; reflections';
      c.insertBefore(a, c.firstChild);
    }
    if (document.readyState !== 'loading') addBack();
    else document.addEventListener('DOMContentLoaded', addBack);
  })();
</script>

{% capture footer_contents %}
  {{ site.footer_text }}
  {% if site.impressum_path %}
    <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
  {% endif %}
  {% if site.last_updated %}
    Last updated: {{ 'now' | date: '%B %d, %Y' }}.
  {% endif %}
{% endcapture %}

{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      {{ footer_contents }}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% if site.plugins contains 'al_newsletter' %}
        {% include plugins/al_newsletter_form_center.liquid %}
      {% else %}
        {% include newsletter.liquid %}
      {% endif %}
    {% endif %}

    <div class="container">
      {{ footer_contents }}
    </div>
  </footer>
{% endif %}
