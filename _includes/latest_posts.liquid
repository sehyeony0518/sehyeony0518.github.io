<style>
  .diary-preview { margin-top: 0.6rem; }
  .diary-preview .dp-item {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 0.85rem 1.05rem;
    margin-bottom: 0.65rem;
    border-radius: 12px;
    border: 1px solid rgba(128, 128, 128, 0.18);
    background: rgba(128, 128, 128, 0.035);
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .diary-preview .dp-item:hover {
    border-color: var(--global-theme-color);
    transform: translateX(4px);
    box-shadow: -3px 0 0 0 var(--global-theme-color);
  }
  .diary-preview .dp-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.28rem;
  }
  .diary-preview .dp-tag {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.12rem 0.55rem;
    border-radius: 999px;
    background: var(--global-theme-color);
    color: #fff;
    white-space: nowrap;
  }
  .diary-preview .dp-date {
    font-size: 0.74rem;
    opacity: 0.5;
    font-variant-numeric: tabular-nums;
  }
  .diary-preview .dp-title {
    font-weight: 600;
    line-height: 1.4;
  }
  .diary-preview .dp-desc {
    font-size: 0.82rem;
    opacity: 0.68;
    margin-top: 0.22rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .diary-preview .dp-more {
    display: inline-block;
    margin-top: 0.3rem;
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--global-theme-color);
  }
  .diary-preview .dp-more:hover { text-decoration: underline; }
</style>

{% if page.latest_posts.limit %}
  {% assign dp_limit = page.latest_posts.limit %}
{% else %}
  {% assign dp_limit = 5 %}
{% endif %}

<div class="diary-preview">
  {% for item in site.posts limit: dp_limit %}
    <a class="dp-item" href="{{ item.url | relative_url }}">
      <div class="dp-meta">
        {% if item.tags.first %}<span class="dp-tag">{{ item.tags.first }}</span>{% endif %}
        <span class="dp-date">{{ item.date | date: '%Y.%m.%d' }}</span>
      </div>
      <div class="dp-title">{{ item.title }}</div>
      {% if item.description %}<div class="dp-desc">{{ item.description }}</div>{% endif %}
    </a>
  {% endfor %}
  <a class="dp-more" href="{{ '/diary/' | relative_url }}">모든 기록 보기 &rarr;</a>
</div>
