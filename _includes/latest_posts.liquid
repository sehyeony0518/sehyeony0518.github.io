<style>
  .diary-preview { margin-top: 0.6rem; }
  .diary-preview .dp-cols { display: grid; grid-template-columns: 1fr; gap: 1.1rem; }
  @media (min-width: 576px) { .diary-preview .dp-cols { grid-template-columns: 1fr 1fr; } }
  .diary-preview .dp-col { display: flex; flex-direction: column; gap: 0.6rem; }
  .diary-preview .dp-col-label {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    opacity: 0.5; margin: 0 0 0.05rem;
  }
  .diary-preview .dp-item {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 0.85rem 1.05rem;
    border-radius: 12px;
    border: 1px solid rgba(128, 128, 128, 0.18);
    background: rgba(128, 128, 128, 0.035);
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .diary-preview .dp-item:hover {
    border-color: var(--global-theme-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07);
  }
  .diary-preview .dp-date {
    font-size: 0.74rem;
    opacity: 0.5;
    font-variant-numeric: tabular-nums;
  }
  .diary-preview .dp-title {
    font-weight: 600;
    line-height: 1.4;
    margin-top: 0.2rem;
  }
  .diary-preview .dp-desc {
    font-size: 0.82rem;
    opacity: 0.68;
    margin-top: 0.22rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .diary-preview .dp-more {
    display: inline-block;
    margin-top: 0.9rem;
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--global-theme-color);
  }
  .diary-preview .dp-more:hover { text-decoration: underline; }
</style>

{% assign meditations = site.posts | where_exp: "post", "post.tags contains '묵상'" %}
{% assign impressions = site.posts | where_exp: "post", "post.tags contains '소감문'" %}

<div class="diary-preview">
  <div class="dp-cols">
    <div class="dp-col">
      <div class="dp-col-label"># 묵상</div>
      {% for item in meditations limit: 3 %}
        <a class="dp-item" href="{{ item.url | relative_url }}">
          <span class="dp-date">{{ item.date | date: '%Y.%m.%d' }}</span>
          <div class="dp-title">{{ item.title }}</div>
          {% if item.description %}<div class="dp-desc">{{ item.description }}</div>{% endif %}
        </a>
      {% endfor %}
    </div>
    <div class="dp-col">
      <div class="dp-col-label"># 소감문</div>
      {% for item in impressions limit: 3 %}
        <a class="dp-item" href="{{ item.url | relative_url }}">
          <span class="dp-date">{{ item.date | date: '%Y.%m.%d' }}</span>
          <div class="dp-title">{{ item.title }}</div>
          {% if item.description %}<div class="dp-desc">{{ item.description }}</div>{% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
  <a class="dp-more" href="{{ '/diary/' | relative_url }}">View All Reflections &rarr;</a>
</div>
